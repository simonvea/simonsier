<section>
  <h2 class="posts__title">{{ postsTitle }}</h2>
  <div class="posts">
    {% for post in posts %}
    <article class="post">
      <h2>
        <a class="post__link" href="{{ post.url | url }}">{{ post.data.title }}</a>
      </h2>
      <p class="post__meta">
        <time datetime="{{ post.date | dateIso }}">{{ post.date | dateReadable }}</time>
        {% if post.data.description %} · {{ post.data.description }}{% endif %}
      </p>
    </article>
    {% endfor %}
  </div>
</section>
